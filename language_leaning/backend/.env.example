# Cultura Backend - Environment Variables
# Copy this file to .env and fill in your values

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cultura
REDIS_URL=redis://localhost:6379/0

JWT_SECRET=dev-secret-change-in-production-to-random-64-chars

# AI Model API Keys (at least one required)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=

# S3-compatible storage (optional)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
