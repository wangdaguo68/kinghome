<Window x:Class="SafeBoxApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="保险箱" Height="720" Width="1120" MinHeight="620" MinWidth="980"
        Background="#141416" Closing="Window_Closing"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <!-- ===== LOGIN PANEL ===== -->
        <Grid x:Name="LoginPanel" VerticalAlignment="Center">
            <Border MaxWidth="380" Padding="0" Background="Transparent">
                <StackPanel>
                    <!-- Icon Area -->
                    <Border Width="72" Height="72" CornerRadius="18"
                            Background="#1E1E22" BorderBrush="#2E2E33" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="箱" FontSize="30" Foreground="#C4A46C"
                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <!-- Title -->
                    <TextBlock Text="保险箱" FontSize="28" FontWeight="SemiBold"
                               FontFamily="Segoe UI, Microsoft YaHei UI"
                               Foreground="#EAE6DD" TextAlignment="Center" Margin="0,0,0,6" />
                    <TextBlock Text="本地加密 · 安全存储" FontSize="12" Foreground="#696660"
                               FontFamily="Segoe UI, Microsoft YaHei UI"
                               TextAlignment="Center" Margin="0,0,0,32" />

                    <!-- Vault Path -->
                    <TextBlock Text="保险箱文件夹" FontSize="11" Foreground="#908E8A"
                               FontFamily="Segoe UI, Microsoft YaHei UI"
                               Margin="0,0,0,8" />
                    <DockPanel Margin="0,0,0,16">
                        <Button Content="选择" DockPanel.Dock="Right" Click="BrowseVault_Click"
                                Style="{StaticResource PrimaryButton}" FontSize="12" Padding="14,8" />
                        <TextBox x:Name="VaultPathBox" Margin="0,0,10,0"
                                 TextChanged="VaultPathBox_TextChanged" />
                    </DockPanel>

                    <!-- Password -->
                    <TextBlock Text="主密码" FontSize="11" Foreground="#908E8A"
                               FontFamily="Segoe UI, Microsoft YaHei UI"
                               Margin="0,0,0,8" />
                    <PasswordBox x:Name="PasswordBox" Margin="0,0,0,12" />

                    <!-- Confirm Password -->
                    <TextBlock x:Name="ConfirmPasswordLabel" Text="确认密码" FontSize="11"
                               Foreground="#908E8A"
                               FontFamily="Segoe UI, Microsoft YaHei UI"
                               Margin="0,0,0,8" />
                    <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,0,0,22" />

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                        <Button x:Name="CreateVaultBtn" Content="创建保险箱" Click="CreateVault_Click"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,10,0" />
                        <Button x:Name="UnlockVaultBtn" Content="解锁" Click="UnlockVault_Click"
                                Style="{StaticResource PrimaryButton}" />
                    </StackPanel>

                    <!-- Recovery Section -->
                    <Expander Header="忘记密码？使用恢复密钥" Margin="0,10,0,0"
                              Foreground="#696660" FontSize="11"
                              FontFamily="Segoe UI, Microsoft YaHei UI"
                              BorderThickness="0">
                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Text="恢复密钥" FontSize="11" Foreground="#908E8A"
                                       FontFamily="Segoe UI, Microsoft YaHei UI"
                                       Margin="0,0,0,8" />
                            <TextBox x:Name="RecoveryKeyBox" Margin="0,0,0,12" />
                            <TextBlock Text="新主密码" FontSize="11" Foreground="#908E8A"
                                       FontFamily="Segoe UI, Microsoft YaHei UI"
                                       Margin="0,0,0,8" />
                            <PasswordBox x:Name="NewPasswordBox" Margin="0,0,0,14" />
                            <Button Content="用恢复密钥重设并解锁" Click="RecoverVault_Click"
                                    Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Expander>

                    <!-- Recovery Output -->
                    <TextBox x:Name="RecoveryOutputBox" Visibility="Collapsed" IsReadOnly="True"
                             TextWrapping="Wrap" Margin="0,16,0,0"
                             Background="#1E1E22" Foreground="#C4A46C" BorderThickness="0"
                             FontSize="11" FontFamily="Segoe UI, Microsoft YaHei UI" />

                    <!-- Status -->
                    <TextBlock x:Name="LoginStatusText" Margin="0,18,0,0" Foreground="#D9665C"
                               FontSize="12" TextWrapping="Wrap" TextAlignment="Center"
                               FontFamily="Segoe UI, Microsoft YaHei UI" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== VAULT PANEL (UNLOCKED) ===== -->
        <Grid x:Name="VaultPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" BorderBrush="#2E2E33" BorderThickness="0,0,0,1"
                    Background="#141416">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="保险箱" FontSize="12" Foreground="#4A4540"
                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                   VerticalAlignment="Center" FontWeight="SemiBold" />
                        <TextBlock Text="  /  " FontSize="12" Foreground="#2E2E33"
                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="BreadcrumbText" Text="全部文件" FontSize="12"
                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                   Foreground="#C4A46C" VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Content="锁定" Click="LockVault_Click"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="11" Padding="12,6"
                            HorizontalAlignment="Right" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar -->
                <Border Grid.Column="0" BorderBrush="#2E2E33" BorderThickness="0,0,1,0"
                        Background="#141416">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListBox x:Name="FolderList" Grid.Row="0"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="#908E8A" FontFamily="Segoe UI, Microsoft YaHei UI"
                                 SelectionChanged="FolderList_SelectionChanged"
                                 Margin="0,14,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="12" Foreground="#908E8A"
                                               FontFamily="Segoe UI, Microsoft YaHei UI"
                                               Padding="16,8" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Button x:Name="NewFolderBtn" Grid.Row="1"
                                Content="+ 新建文件夹" Click="NewFolder_Click"
                                Style="{StaticResource GhostButton}"
                                Foreground="#696660"
                                HorizontalAlignment="Stretch" Margin="8,0,8,14" />
                    </Grid>
                </Border>

                <!-- Center File Grid -->
                <Grid Grid.Column="1" Background="#16161A">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Orientation="Horizontal" Margin="20,16,20,0" Grid.Row="0">
                        <Button Content="导入并加密" Click="ImportFiles_Click"
                                Style="{StaticResource PrimaryButton}" FontSize="12" Padding="14,8" />
                        <Button Content="导出" Click="ExportFile_Click"
                                Style="{StaticResource SecondaryButton}" FontSize="12"
                                Margin="10,0,0,0" />
                        <Button Content="删除" Click="DeleteFile_Click"
                                Style="{StaticResource SecondaryButton}" FontSize="12"
                                Margin="10,0,0,0" />
                        <TextBlock x:Name="ItemCountText" Text="0 个项目"
                                   FontSize="11" Foreground="#4A4540"
                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                   VerticalAlignment="Center" Margin="20,0,0,0" />
                    </StackPanel>

                    <!-- File List -->
                    <ListView x:Name="ItemsList" Grid.Row="1"
                              SelectionChanged="ItemsList_SelectionChanged"
                              MouseDoubleClick="ItemsList_MouseDoubleClick"
                              Margin="20,14,20,14" Background="Transparent"
                              BorderThickness="0" FontFamily="Segoe UI, Microsoft YaHei UI">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="32">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="名称" DisplayMemberBinding="{Binding DisplayName}"
                                                Width="220" />
                                <GridViewColumn Header="大小" DisplayMemberBinding="{Binding SizeText}"
                                                Width="80" />
                                <GridViewColumn Header="类型" DisplayMemberBinding="{Binding TypeText}"
                                                Width="80" />
                                <GridViewColumn Header="日期" DisplayMemberBinding="{Binding DateText}"
                                                Width="120" />
                            </GridView>
                        </ListView.View>
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="导出" Click="ContextMenu_Export_Click" />
                                <MenuItem Header="导出后删除" Click="ContextMenu_ExportDelete_Click" />
                                <Separator />
                                <MenuItem Header="删除" Click="ContextMenu_Delete_Click" />
                                <Separator />
                                <MenuItem Header="打开" Click="ContextMenu_Open_Click" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                    </ListView>
                </Grid>

                <!-- Right Preview Panel -->
                <Border Grid.Column="2" BorderBrush="#2E2E33" BorderThickness="1,0,0,0"
                        Background="#141416" Width="260">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="PreviewTitle" Grid.Row="0" Text="选择文件预览"
                                   FontSize="11" Foreground="#696660"
                                   FontFamily="Segoe UI, Microsoft YaHei UI"
                                   Margin="0,0,0,14" />

                        <Border Grid.Row="1" Background="#1E1E22" CornerRadius="8">
                            <Grid>
                                <Image x:Name="PreviewImage" Stretch="Uniform" Visibility="Collapsed" />
                                <MediaElement x:Name="PreviewVideo" LoadedBehavior="Manual"
                                              UnloadedBehavior="Manual" Stretch="Uniform"
                                              Visibility="Collapsed" />
                                <TextBox x:Name="PreviewText" Visibility="Collapsed" IsReadOnly="True"
                                         TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#1E1E22" Foreground="#EAE6DD"
                                         BorderThickness="0" FontSize="12"
                                         FontFamily="Segoe UI, Microsoft YaHei UI" />
                                <TextBlock x:Name="PreviewMessage" Text="选择一个文件预览"
                                           Foreground="#696660" FontSize="12"
                                           FontFamily="Segoe UI, Microsoft YaHei UI"
                                           TextAlignment="Center" VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom Status Bar -->
            <Border Grid.Row="2" BorderBrush="#2E2E33" BorderThickness="0,1,0,0"
                    Background="#141416">
                <TextBlock x:Name="StatusText" FontSize="10" Foreground="#4A4540"
                           FontFamily="Segoe UI, Microsoft YaHei UI"
                           VerticalAlignment="Center" Margin="16,0" TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Grid>
</Window>
