# Zen Trader 环境变量配置
# 复制此文件为 .env 并填入真实值

# Anthropic (Claude) API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# OpenAI API (可选，切换 provider 时使用)
OPENAI_API_KEY=sk-xxxxxxxxxx

# 自定义 API 代理地址 (可选，留空使用官方默认)
# API_BASE=https://your-proxy.com/v1

# AI 请求超时秒数，避免上游接口卡住导致页面一直生成中
AI_TIMEOUT_SECONDS=90

# 微信公众号发布 (可选)
WECHAT_APP_ID=wx_xxxxxxxxxx
WECHAT_APP_SECRET=xxxxxxxxxx
# 可选：微信图文 author 字段限制很短，留空最稳
WECHAT_AUTHOR=
WECHAT_DIGEST=禅意复盘
# 可选：已上传到公众号永久素材库的封面 media_id，留空则自动生成并上传默认封面
# WECHAT_THUMB_MEDIA_ID=xxxxxxxxxx
# 可选：默认封面生成使用的中文字体路径，服务器缺中文字体时建议显式配置
# WECHAT_COVER_FONT=/opt/media_factory/fonts/msyh.ttc
